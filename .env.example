# Copy to .env and fill in. .env is gitignored.

# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Free model on OpenRouter used for lead extraction
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Optional fallback model(s) tried if the primary fails or returns bad JSON.
# Single id, or a comma-separated chain for extra resilience under free-tier
# rate limits, e.g.:
# OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free
OPENROUTER_FALLBACK_MODEL=
